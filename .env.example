AGENT_SERVER_ADDR=:8080
AGENT_SERVER_ENV=dev
AGENT_SERVER_NAME=agent-server
AGENT_SERVER_VERSION=0.1.0-dev

AGENT_SERVER_REALTIME_WS_PATH=/v1/realtime/ws
AGENT_SERVER_REALTIME_PROTOCOL_VERSION=rtos-ws-v0
AGENT_SERVER_REALTIME_SUBPROTOCOL=agent-server.realtime.v0
AGENT_SERVER_REALTIME_AUTH_MODE=disabled
AGENT_SERVER_REALTIME_TURN_MODE=client_wakeup_server_vad
AGENT_SERVER_REALTIME_IDLE_TIMEOUT_MS=15000
AGENT_SERVER_REALTIME_MAX_SESSION_MS=300000
AGENT_SERVER_REALTIME_MAX_FRAME_BYTES=4096

AGENT_SERVER_REALTIME_INPUT_CODEC=pcm16le
AGENT_SERVER_REALTIME_INPUT_SAMPLE_RATE=16000
AGENT_SERVER_REALTIME_INPUT_CHANNELS=1
AGENT_SERVER_REALTIME_OUTPUT_CODEC=pcm16le
AGENT_SERVER_REALTIME_OUTPUT_SAMPLE_RATE=16000
AGENT_SERVER_REALTIME_OUTPUT_CHANNELS=1

AGENT_SERVER_REALTIME_ALLOW_OPUS=true
AGENT_SERVER_REALTIME_ALLOW_TEXT_INPUT=true
AGENT_SERVER_REALTIME_ALLOW_IMAGE_INPUT=false

AGENT_SERVER_VOICE_PROVIDER=bootstrap
AGENT_SERVER_VOICE_ASR_URL=http://127.0.0.1:8091/v1/asr/transcribe
AGENT_SERVER_VOICE_ASR_TIMEOUT_MS=30000
AGENT_SERVER_VOICE_ASR_LANGUAGE=auto
AGENT_SERVER_VOICE_EMIT_PLACEHOLDER_AUDIO=true

AGENT_SERVER_TTS_PROVIDER=none
AGENT_SERVER_TTS_MIMO_BASE_URL=https://api.xiaomimimo.com/v1
AGENT_SERVER_TTS_MIMO_MODEL=mimo-v2-tts
AGENT_SERVER_TTS_MIMO_VOICE=mimo_default
AGENT_SERVER_TTS_MIMO_STYLE=
AGENT_SERVER_TTS_TIMEOUT_MS=30000
