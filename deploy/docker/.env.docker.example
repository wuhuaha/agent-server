# Copy this file to deploy/docker/.env.docker before running docker compose.

AGENT_SERVER_ADDR=:8080
AGENT_SERVER_ENV=docker
AGENT_SERVER_NAME=agent-server
AGENT_SERVER_VERSION=0.1.0-docker

AGENT_SERVER_REALTIME_WS_PATH=/v1/realtime/ws
AGENT_SERVER_REALTIME_PROTOCOL_VERSION=rtos-ws-v0
AGENT_SERVER_REALTIME_SUBPROTOCOL=agent-server.realtime.v0
AGENT_SERVER_REALTIME_AUTH_MODE=disabled
AGENT_SERVER_REALTIME_TURN_MODE=client_wakeup_client_commit
AGENT_SERVER_REALTIME_IDLE_TIMEOUT_MS=15000
AGENT_SERVER_REALTIME_MAX_SESSION_MS=300000
AGENT_SERVER_REALTIME_MAX_FRAME_BYTES=4096
AGENT_SERVER_REALTIME_INPUT_CODEC=pcm16le
AGENT_SERVER_REALTIME_INPUT_SAMPLE_RATE=16000
AGENT_SERVER_REALTIME_INPUT_CHANNELS=1
AGENT_SERVER_REALTIME_OUTPUT_CODEC=pcm16le
AGENT_SERVER_REALTIME_OUTPUT_SAMPLE_RATE=16000
AGENT_SERVER_REALTIME_OUTPUT_CHANNELS=1
AGENT_SERVER_REALTIME_ALLOW_OPUS=true
AGENT_SERVER_REALTIME_ALLOW_TEXT_INPUT=true
AGENT_SERVER_REALTIME_ALLOW_IMAGE_INPUT=false

AGENT_SERVER_XIAOZHI_ENABLED=false
AGENT_SERVER_XIAOZHI_WS_PATH=/xiaozhi/v1/
AGENT_SERVER_XIAOZHI_OTA_PATH=/xiaozhi/ota/
AGENT_SERVER_XIAOZHI_WELCOME_VERSION=1
AGENT_SERVER_XIAOZHI_WELCOME_TRANSPORT=websocket
AGENT_SERVER_XIAOZHI_INPUT_CODEC=opus
AGENT_SERVER_XIAOZHI_INPUT_SAMPLE_RATE=16000
AGENT_SERVER_XIAOZHI_INPUT_CHANNELS=1
AGENT_SERVER_XIAOZHI_INPUT_FRAME_DURATION_MS=60
AGENT_SERVER_XIAOZHI_MAX_FRAME_BYTES=4096
AGENT_SERVER_XIAOZHI_IDLE_TIMEOUT_MS=15000
AGENT_SERVER_XIAOZHI_MAX_SESSION_MS=300000
AGENT_SERVER_XIAOZHI_OUTPUT_CODEC=opus
AGENT_SERVER_XIAOZHI_OUTPUT_SAMPLE_RATE=24000
AGENT_SERVER_XIAOZHI_OUTPUT_CHANNELS=1
AGENT_SERVER_XIAOZHI_OUTPUT_FRAME_DURATION_MS=60

AGENT_SERVER_AGENT_MEMORY_PROVIDER=in_memory
AGENT_SERVER_AGENT_MEMORY_MAX_TURNS=8
AGENT_SERVER_AGENT_TOOL_PROVIDER=builtin
AGENT_SERVER_AGENT_SKILLS=household_control
AGENT_SERVER_AGENT_LLM_PROVIDER=bootstrap
AGENT_SERVER_AGENT_LLM_TIMEOUT_MS=30000
AGENT_SERVER_AGENT_PERSONA=household_control_screen
AGENT_SERVER_AGENT_EXECUTION_MODE=simulation
AGENT_SERVER_AGENT_ASSISTANT_NAME=小欧管家
AGENT_SERVER_AGENT_LLM_SYSTEM_PROMPT=
AGENT_SERVER_AGENT_DEEPSEEK_BASE_URL=https://api.deepseek.com
AGENT_SERVER_AGENT_DEEPSEEK_API_KEY=
AGENT_SERVER_AGENT_DEEPSEEK_MODEL=deepseek-chat
AGENT_SERVER_AGENT_DEEPSEEK_TEMPERATURE=0.2
AGENT_SERVER_AGENT_DEEPSEEK_MAX_TOKENS=0

# compose.local-asr.yml overrides these two values for the agentd service.
AGENT_SERVER_VOICE_PROVIDER=bootstrap
AGENT_SERVER_VOICE_ASR_URL=http://funasr-worker:8091/v1/asr/transcribe
AGENT_SERVER_VOICE_ASR_TIMEOUT_MS=30000
AGENT_SERVER_VOICE_ASR_LANGUAGE=auto
AGENT_SERVER_VOICE_SERVER_ENDPOINT_ENABLED=false
AGENT_SERVER_VOICE_SERVER_ENDPOINT_MIN_AUDIO_MS=320
AGENT_SERVER_VOICE_SERVER_ENDPOINT_SILENCE_MS=480
AGENT_SERVER_VOICE_SERVER_ENDPOINT_LEXICAL_MODE=conservative
AGENT_SERVER_VOICE_SERVER_ENDPOINT_INCOMPLETE_HOLD_MS=720
AGENT_SERVER_VOICE_SERVER_ENDPOINT_HINT_SILENCE_MS=160
AGENT_SERVER_VOICE_BARGE_IN_MIN_AUDIO_MS=120
AGENT_SERVER_VOICE_BARGE_IN_HOLD_AUDIO_MS=240
AGENT_SERVER_VOICE_SPEECH_PLANNER_ENABLED=true
AGENT_SERVER_VOICE_SPEECH_PLANNER_MIN_CHUNK_RUNES=6
AGENT_SERVER_VOICE_SPEECH_PLANNER_TARGET_CHUNK_RUNES=24
AGENT_SERVER_VOICE_EMIT_PLACEHOLDER_AUDIO=true

AGENT_SERVER_TTS_PROVIDER=none
AGENT_SERVER_TTS_MIMO_BASE_URL=https://api.xiaomimimo.com/v1
AGENT_SERVER_TTS_MIMO_MODEL=mimo-v2-tts
AGENT_SERVER_TTS_MIMO_VOICE=mimo_default
AGENT_SERVER_TTS_MIMO_STYLE=
AGENT_SERVER_TTS_TIMEOUT_MS=30000
AGENT_SERVER_TTS_COSYVOICE_BASE_URL=http://cosyvoice-tts:50000
AGENT_SERVER_TTS_COSYVOICE_MODE=sft
AGENT_SERVER_TTS_COSYVOICE_SPK_ID=中文女
AGENT_SERVER_TTS_COSYVOICE_INSTRUCT_TEXT=
AGENT_SERVER_TTS_COSYVOICE_SOURCE_SAMPLE_RATE=22050
MIMO_API_KEY=
COSYVOICE_IMAGE=cosyvoice:v1.0
COSYVOICE_MODEL_DIR=iic/CosyVoice-300M-SFT

AGENT_SERVER_FUNASR_MODEL=iic/SenseVoiceSmall
AGENT_SERVER_FUNASR_ONLINE_MODEL=
AGENT_SERVER_FUNASR_FINAL_VAD_MODEL=
AGENT_SERVER_FUNASR_FINAL_PUNC_MODEL=
AGENT_SERVER_FUNASR_LANGUAGE=auto
AGENT_SERVER_FUNASR_BATCH_SIZE_S=60
AGENT_SERVER_FUNASR_DISABLE_UPDATE=true
AGENT_SERVER_FUNASR_TRUST_REMOTE_CODE=false
AGENT_SERVER_FUNASR_USE_ITN=true
AGENT_SERVER_FUNASR_FINAL_MERGE_VAD=true
AGENT_SERVER_FUNASR_FINAL_MERGE_LENGTH_S=15
AGENT_SERVER_FUNASR_STREAM_CHUNK_SIZE=0,10,5
AGENT_SERVER_FUNASR_STREAM_ENCODER_CHUNK_LOOK_BACK=4
AGENT_SERVER_FUNASR_STREAM_DECODER_CHUNK_LOOK_BACK=1
AGENT_SERVER_FUNASR_KWS_ENABLED=false
AGENT_SERVER_FUNASR_KWS_MODEL=fsmn-kws
AGENT_SERVER_FUNASR_KWS_KEYWORDS=
AGENT_SERVER_FUNASR_KWS_STRIP_MATCHED_PREFIX=true
AGENT_SERVER_FUNASR_KWS_MIN_AUDIO_MS=480
AGENT_SERVER_FUNASR_KWS_MIN_INTERVAL_MS=400
AGENT_SERVER_FUNASR_STREAM_PREVIEW_MIN_AUDIO_MS=320
AGENT_SERVER_FUNASR_STREAM_PREVIEW_MIN_INTERVAL_MS=240
AGENT_SERVER_FUNASR_STREAM_ENDPOINT_TAIL_MS=160
AGENT_SERVER_FUNASR_STREAM_ENDPOINT_MEAN_ABS_THRESHOLD=180
AGENT_SERVER_FUNASR_STREAM_ENDPOINT_VAD_PROVIDER=energy
AGENT_SERVER_FUNASR_STREAM_ENDPOINT_VAD_THRESHOLD=0.5
AGENT_SERVER_FUNASR_STREAM_ENDPOINT_VAD_MIN_SILENCE_MS=160
AGENT_SERVER_FUNASR_STREAM_ENDPOINT_VAD_SPEECH_PAD_MS=30

MODELSCOPE_CACHE=/models/modelscope
HF_HOME=/models/hf
TORCH_HOME=/models/torch
