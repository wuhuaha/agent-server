AGENT_SERVER_ADDR=0.0.0.0:8080
AGENT_SERVER_VOICE_PROVIDER=funasr_http
AGENT_SERVER_VOICE_ASR_URL=http://127.0.0.1:8091/v1/asr/transcribe
AGENT_SERVER_VOICE_ASR_LANGUAGE=auto
AGENT_SERVER_VOICE_EMIT_PLACEHOLDER_AUDIO=false
AGENT_SERVER_VOICE_BARGE_IN_MIN_AUDIO_MS=120
AGENT_SERVER_VOICE_BARGE_IN_HOLD_AUDIO_MS=240
AGENT_SERVER_VOICE_SPEECH_PLANNER_ENABLED=true
AGENT_SERVER_VOICE_SPEECH_PLANNER_MIN_CHUNK_RUNES=6
AGENT_SERVER_VOICE_SPEECH_PLANNER_TARGET_CHUNK_RUNES=24
AGENT_SERVER_TTS_PROVIDER=none
AGENT_SERVER_AGENT_LLM_PROVIDER=bootstrap
AGENT_SERVER_BINARY=/home/ubuntu/agent-server/bin/agentd
