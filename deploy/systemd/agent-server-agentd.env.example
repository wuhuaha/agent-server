AGENT_SERVER_ADDR=0.0.0.0:8080
AGENT_SERVER_VOICE_PROVIDER=funasr_http
AGENT_SERVER_VOICE_ASR_URL=http://127.0.0.1:8091/v1/asr/transcribe
AGENT_SERVER_VOICE_ASR_LANGUAGE=auto
AGENT_SERVER_VOICE_ASR_READY_TIMEOUT_SEC=180
AGENT_SERVER_VOICE_ASR_READY_POLL_INTERVAL_SEC=2
AGENT_SERVER_VOICE_EMIT_PLACEHOLDER_AUDIO=false
AGENT_SERVER_VOICE_BARGE_IN_MIN_AUDIO_MS=120
AGENT_SERVER_VOICE_BARGE_IN_HOLD_AUDIO_MS=240
AGENT_SERVER_VOICE_SPEECH_PLANNER_ENABLED=true
AGENT_SERVER_VOICE_SPEECH_PLANNER_MIN_CHUNK_RUNES=6
AGENT_SERVER_VOICE_SPEECH_PLANNER_TARGET_CHUNK_RUNES=24
AGENT_SERVER_TTS_PROVIDER=none
# To switch agentd to the local GPU TTS runtime after CosyVoice FastAPI is ready:
# AGENT_SERVER_TTS_PROVIDER=cosyvoice_http
# AGENT_SERVER_TTS_COSYVOICE_BASE_URL=http://127.0.0.1:50000
# AGENT_SERVER_TTS_COSYVOICE_MODE=sft
# AGENT_SERVER_TTS_COSYVOICE_SPK_ID=中文女
# AGENT_SERVER_TTS_COSYVOICE_INSTRUCT_TEXT=
# AGENT_SERVER_TTS_COSYVOICE_SOURCE_SAMPLE_RATE=22050
AGENT_SERVER_AGENT_LLM_PROVIDER=bootstrap
# To switch agentd to a local OpenAI-compatible LLM worker such as Qwen3:
# AGENT_SERVER_AGENT_LLM_PROVIDER=deepseek_chat
# AGENT_SERVER_AGENT_DEEPSEEK_BASE_URL=http://127.0.0.1:8012/v1
# AGENT_SERVER_AGENT_DEEPSEEK_API_KEY=local-llm
# AGENT_SERVER_AGENT_DEEPSEEK_MODEL=Qwen/Qwen3-4B-Instruct-2507
# AGENT_SERVER_AGENT_LLM_TIMEOUT_MS=60000
AGENT_SERVER_BINARY=/home/ubuntu/agent-server/bin/agentd
