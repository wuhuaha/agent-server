# Explicit vertical overlay for the household demo.
#
# Usage:
#   1. Start from the generic repository defaults in .env.example
#   2. Merge or source this file explicitly when you want the household demo
#      capability, instead of changing the shared defaults
#
# Example:
#   cp .env.example .env.household
#   cat profiles/household-demo.env.example >> .env.household
#   # then uncomment optional lines as needed

# Required for the household demo path.
AGENT_SERVER_AGENT_SKILLS=household_control

# Optional screen-oriented persona and assistant naming.
# AGENT_SERVER_AGENT_PERSONA=household_control_screen
# AGENT_SERVER_AGENT_ASSISTANT_NAME=小欧管家

# Optional demo-stage feedback style for simulated control completion.
# AGENT_SERVER_AGENT_EXECUTION_MODE=simulation

# Optional seed grounding profile for household and desktop alias research.
# AGENT_SERVER_VOICE_ENTITY_CATALOG_PROFILE=seed_companion
