{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-server.local/schemas/realtime/session-envelope.schema.json",
  "title": "Realtime Session Envelope",
  "type": "object",
  "required": [
    "type",
    "seq",
    "ts",
    "payload"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "session.start",
        "session.update",
        "audio.in.append",
        "audio.in.commit",
        "text.in",
        "image.in",
        "response.start",
        "response.chunk",
        "audio.out.chunk",
        "session.end",
        "error"
      ]
    },
    "session_id": {
      "type": "string"
    },
    "seq": {
      "type": "integer",
      "minimum": 0
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "description": "Event-specific payload. response.chunk currently carries text or structured tool deltas via fields such as response_id, delta_type, text, tool_call_id, tool_name, tool_status, tool_input, and tool_output."
    },
    "auth": {
      "type": "object"
    },
    "device": {
      "type": "object"
    },
    "trace": {
      "type": "object"
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "session.update"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "oneOf": [
              {
                "required": [
                  "state"
                ],
                "properties": {
                  "state": {
                    "type": "string",
                    "enum": [
                      "active",
                      "thinking",
                      "speaking"
                    ]
                  },
                  "barge_in_enabled": {
                    "type": "boolean"
                  },
                  "turn_id": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              },
              {
                "required": [
                  "interrupt"
                ],
                "properties": {
                  "interrupt": {
                    "type": "boolean"
                  }
                },
                "additionalProperties": true
              },
              {
                "maxProperties": 0
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "response.chunk"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "response_id",
              "delta_type"
            ],
            "properties": {
              "response_id": {
                "type": "string"
              },
              "delta_type": {
                "type": "string",
                "enum": [
                  "text",
                  "tool_call",
                  "tool_result"
                ]
              },
              "text": {
                "type": "string"
              },
              "tool_call_id": {
                "type": "string"
              },
              "tool_name": {
                "type": "string"
              },
              "tool_status": {
                "type": "string"
              },
              "tool_input": {
                "type": "string"
              },
              "tool_output": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      }
    }
  ]
}
