{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-server.local/schemas/realtime/session-envelope.schema.json",
  "title": "Realtime Session Envelope",
  "type": "object",
  "required": [
    "type",
    "seq",
    "ts",
    "payload"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "session.start",
        "session.update",
        "audio.in.append",
        "audio.in.commit",
        "text.in",
        "image.in",
        "response.start",
        "response.chunk",
        "audio.out.chunk",
        "session.end",
        "error"
      ]
    },
    "session_id": {
      "type": "string"
    },
    "seq": {
      "type": "integer",
      "minimum": 0
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "description": "Event-specific payload. response.chunk currently carries text or structured tool deltas via fields such as response_id, delta_type, text, tool_call_id, tool_name, tool_status, tool_input, and tool_output."
    },
    "auth": {
      "type": "object"
    },
    "device": {
      "type": "object"
    },
    "trace": {
      "type": "object"
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "response.start"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "response_id"
            ],
            "properties": {
              "response_id": {
                "type": "string"
              },
              "modalities": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "turn_id": {
                "type": "string"
              },
              "trace_id": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "session.update"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "oneOf": [
              {
                "required": [
                  "state"
                ],
                "properties": {
                  "state": {
                    "type": "string",
                    "enum": [
                      "idle",
                      "active",
                      "thinking",
                      "speaking",
                      "closing"
                    ],
                    "description": "Top-level compatibility state. Newer servers may also expose input_state and output_state for split-lane details."
                  },
                  "input_state": {
                    "type": "string",
                    "enum": [
                      "idle",
                      "active",
                      "previewing",
                      "committed",
                      "closing"
                    ],
                    "description": "Optional input-lane substate for richer realtime UX."
                  },
                  "output_state": {
                    "type": "string",
                    "enum": [
                      "idle",
                      "thinking",
                      "speaking",
                      "closing"
                    ],
                    "description": "Optional output-lane substate for split input/output orchestration."
                  },
                  "barge_in_enabled": {
                    "type": "boolean",
                    "description": "Whether the current session runtime allows speaking-time interruption attempts."
                  },
                  "turn_id": {
                    "type": "string",
                    "description": "Optional correlation identifier for the current turn lifecycle. Its presence alone does not mean a new user turn was accepted."
                  },
                  "accept_reason": {
                    "type": "string",
                    "description": "Optional accepted-turn reason such as audio_commit, server_endpoint, or text_input. Omitted on preview-only or compatibility updates that did not accept a new turn."
                  }
                },
                "additionalProperties": true
              },
              {
                "required": [
                  "interrupt"
                ],
                "properties": {
                  "interrupt": {
                    "type": "boolean"
                  }
                },
                "additionalProperties": true
              },
              {
                "maxProperties": 0
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "response.chunk"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "response_id",
              "delta_type"
            ],
            "properties": {
              "response_id": {
                "type": "string"
              },
              "delta_type": {
                "type": "string",
                "enum": [
                  "text",
                  "tool_call",
                  "tool_result"
                ]
              },
              "text": {
                "type": "string"
              },
              "tool_call_id": {
                "type": "string"
              },
              "tool_name": {
                "type": "string"
              },
              "tool_status": {
                "type": "string"
              },
              "tool_input": {
                "type": "string"
              },
              "tool_output": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      }
    }
  ]
}
