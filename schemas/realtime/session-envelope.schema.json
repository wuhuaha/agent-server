{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-server.local/schemas/realtime/session-envelope.schema.json",
  "title": "Realtime Session Envelope",
  "type": "object",
  "required": [
    "type",
    "seq",
    "ts",
    "payload"
  ],
  "properties": {
    "type": {
      "type": "string",
      "enum": [
        "session.start",
        "session.update",
        "audio.in.append",
        "audio.in.commit",
        "text.in",
        "image.in",
        "input.speech.start",
        "input.preview",
        "input.endpoint",
        "response.start",
        "response.chunk",
        "audio.out.meta",
        "audio.out.chunk",
        "audio.out.started",
        "audio.out.mark",
        "audio.out.cleared",
        "audio.out.completed",
        "session.end",
        "error"
      ]
    },
    "session_id": {
      "type": "string"
    },
    "seq": {
      "type": "integer",
      "minimum": 0
    },
    "ts": {
      "type": "string",
      "format": "date-time"
    },
    "payload": {
      "type": "object",
      "description": "Event-specific payload. response.chunk carries text or structured tool deltas, input.* events carry preview-aware speech observations, and audio.out.* control events carry playback metadata or client playback facts."
    },
    "auth": {
      "type": "object"
    },
    "device": {
      "type": "object"
    },
    "trace": {
      "type": "object"
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "type": {
            "const": "input.speech.start"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "preview_id",
              "audio_offset_ms",
              "source"
            ],
            "properties": {
              "preview_id": {
                "type": "string"
              },
              "audio_offset_ms": {
                "type": "integer",
                "minimum": 0
              },
              "source": {
                "type": "string",
                "enum": [
                  "server_preview"
                ]
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "input.preview"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "preview_id",
              "text",
              "is_final",
              "audio_offset_ms"
            ],
            "properties": {
              "preview_id": {
                "type": "string"
              },
              "text": {
                "type": "string"
              },
              "stable_prefix": {
                "type": "string",
                "description": "Observational converged-prefix hint for the current preview text. This is not accepted-turn confirmation."
              },
              "is_final": {
                "type": "boolean"
              },
              "stability": {
                "type": "number",
                "description": "Advisory 0..1 stability hint derived from preview text versus stable_prefix.",
                "minimum": 0,
                "maximum": 1
              },
              "audio_offset_ms": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "input.endpoint"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "preview_id",
              "candidate",
              "reason",
              "audio_offset_ms"
            ],
            "properties": {
              "preview_id": {
                "type": "string"
              },
              "candidate": {
                "type": "boolean"
              },
              "reason": {
                "type": "string"
              },
              "audio_offset_ms": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "response.start"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "response_id"
            ],
            "properties": {
              "response_id": {
                "type": "string"
              },
              "modalities": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "turn_id": {
                "type": "string"
              },
              "trace_id": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "session.update"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "oneOf": [
              {
                "required": [
                  "state"
                ],
                "properties": {
                  "state": {
                    "type": "string",
                    "enum": [
                      "idle",
                      "active",
                      "thinking",
                      "speaking",
                      "closing"
                    ],
                    "description": "Top-level compatibility state. Newer servers may also expose input_state and output_state for split-lane details."
                  },
                  "input_state": {
                    "type": "string",
                    "enum": [
                      "idle",
                      "active",
                      "previewing",
                      "committed",
                      "closing"
                    ],
                    "description": "Optional input-lane substate for richer realtime UX."
                  },
                  "output_state": {
                    "type": "string",
                    "enum": [
                      "idle",
                      "thinking",
                      "speaking",
                      "closing"
                    ],
                    "description": "Optional output-lane substate for split input/output orchestration."
                  },
                  "barge_in_enabled": {
                    "type": "boolean",
                    "description": "Whether the current session runtime allows speaking-time interruption attempts."
                  },
                  "turn_id": {
                    "type": "string",
                    "description": "Optional correlation identifier for the current turn lifecycle. Its presence alone does not mean a new user turn was accepted."
                  },
                  "accept_reason": {
                    "type": "string",
                    "description": "Optional accepted-turn reason such as audio_commit, server_endpoint, or text_input. Omitted on preview-only or compatibility updates that did not accept a new turn."
                  }
                },
                "additionalProperties": true
              },
              {
                "required": [
                  "interrupt"
                ],
                "properties": {
                  "interrupt": {
                    "type": "boolean"
                  }
                },
                "additionalProperties": true
              },
              {
                "maxProperties": 0
              }
            ]
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "audio.out.meta"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "response_id",
              "playback_id",
              "segment_id",
              "expected_duration_ms",
              "is_last_segment"
            ],
            "properties": {
              "response_id": {
                "type": "string"
              },
              "playback_id": {
                "type": "string"
              },
              "segment_id": {
                "type": "string"
              },
              "text": {
                "type": "string"
              },
              "expected_duration_ms": {
                "type": "integer",
                "minimum": 0
              },
              "is_last_segment": {
                "type": "boolean"
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "response.chunk"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "response_id",
              "delta_type"
            ],
            "properties": {
              "response_id": {
                "type": "string"
              },
              "delta_type": {
                "type": "string",
                "enum": [
                  "text",
                  "tool_call",
                  "tool_result"
                ]
              },
              "text": {
                "type": "string"
              },
              "tool_call_id": {
                "type": "string"
              },
              "tool_name": {
                "type": "string"
              },
              "tool_status": {
                "type": "string"
              },
              "tool_input": {
                "type": "string"
              },
              "tool_output": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "audio.out.started"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "response_id",
              "playback_id",
              "segment_id"
            ],
            "properties": {
              "response_id": {
                "type": "string"
              },
              "playback_id": {
                "type": "string"
              },
              "segment_id": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "audio.out.mark"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "response_id",
              "playback_id",
              "segment_id"
            ],
            "properties": {
              "response_id": {
                "type": "string"
              },
              "playback_id": {
                "type": "string"
              },
              "segment_id": {
                "type": "string"
              },
              "played_duration_ms": {
                "type": "integer",
                "minimum": 0
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "audio.out.cleared"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "response_id",
              "playback_id",
              "cleared_after_segment_id",
              "reason"
            ],
            "properties": {
              "response_id": {
                "type": "string"
              },
              "playback_id": {
                "type": "string"
              },
              "cleared_after_segment_id": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "type": {
            "const": "audio.out.completed"
          }
        },
        "required": [
          "type"
        ]
      },
      "then": {
        "properties": {
          "payload": {
            "type": "object",
            "required": [
              "response_id",
              "playback_id"
            ],
            "properties": {
              "response_id": {
                "type": "string"
              },
              "playback_id": {
                "type": "string"
              }
            },
            "additionalProperties": true
          }
        }
      }
    }
  ]
}
